      <mxGeometry x="300" y="10" width="560" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="init" value="" style="ellipse;shape=doubleEllipse;fillColor=#000000;strokeColor=#000000;html=1;" vertex="1" parent="1">
