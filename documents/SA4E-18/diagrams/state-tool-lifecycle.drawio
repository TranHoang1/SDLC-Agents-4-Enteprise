      <mxGeometry x="330" y="230" width="170" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="extended" value="&lt;b&gt;EXTENDED (hidden)&lt;/b&gt;&#10;absent from ListTools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="330" y="400" width="170" height="60" as="geometry"/>
