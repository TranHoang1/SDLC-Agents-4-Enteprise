    <mxCell id="s1" value="server startup" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="init" target="registered"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="s2" value="startup index build (full set)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="registered" target="ingested"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="s3" value="name IN CORE_TOOLS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ingested" target="core"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="s4" value="name NOT in CORE_TOOLS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ingested" target="extended"><mxGeometry relative="1" as="geometry"/></mxCell>
