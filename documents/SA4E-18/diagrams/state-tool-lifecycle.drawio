    <mxCell id="discovered" value="&lt;b&gt;DISCOVERED&lt;/b&gt;&#10;via find_tools(query)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="620" y="400" width="170" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="invoked" value="&lt;b&gt;INVOKED&lt;/b&gt;&#10;CallTool / execute_dynamic_tool" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="620" y="230" width="180" height="60" as="geometry"/>
