    </mxCell>
    <mxCell id="registered" value="&lt;b&gt;REGISTERED&lt;/b&gt;&#10;Tool in ModuleRegistry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="40" y="160" width="160" height="60" as="geometry"/>
    </mxCell>
