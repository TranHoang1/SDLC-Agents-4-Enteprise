# -------------------------------------------------------
# SDLC Agents 4 Enterprise — runtime environment
# Copy to .env and fill in values before running.
# -------------------------------------------------------

# Path on the HOST to the source code workspace to analyze.
# It is mounted read-only inside the container at /workspace.
WORKSPACE_PATH=./

# ---- Server ----
CODE_INTEL_PORT=48721
LOG_LEVEL=info          # debug | info | warn | error

# ---- LLM provider -----------------------------------------------
# ollama   → needs the ollama service (bundled in docker-compose)
# openai   → set LLM_BASE_URL + LLM_API_KEY
# anthropic→ set LLM_BASE_URL + LLM_API_KEY
# lmstudio → set LLM_BASE_URL (e.g. http://host.docker.internal:1234/v1)
# -----------------------------------------------------------------
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
LLM_API_KEY=

# ---- Optional Jira integration ----
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_USER=you@yourcompany.com
# JIRA_TOKEN=your-api-token
